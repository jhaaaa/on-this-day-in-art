                                    "    pm.test('Response references June or date context', () => {",
                                    "        const lower = content.toLowerCase();",
                                    "        pm.expect(lower.includes('june') || lower.includes('month') || lower.includes('date')).to.be.true;",
                                    "    });",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
